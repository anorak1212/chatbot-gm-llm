# Environment variables for Chatbot GM LLM
# Copy this file to .env and fill in your actual values

# ============================================
# Neo4j Configuration
# ============================================
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=admin1234

# ============================================
# LM Studio Configuration
# ============================================
LM_STUDIO_URL=http://192.168.1.80:1234
LM_STUDIO_MODEL=gemma-4-e4b-it

# ============================================
# API Configuration
# ============================================
API_HOST=0.0.0.0
API_PORT=8000

# ============================================
# Chainlit Configuration
# ============================================
CHAINLIT_HOST=0.0.0.0
CHAINLIT_PORT=8001
